{
  "name": "@percolator/devnet-mm",
  "version": "1.0.0",
  "description": "Percolator devnet market-making bots — filler + two-sided quoter",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsx src/index.ts",
    "start:filler": "BOT_MODE=filler tsx src/index.ts",
    "start:maker": "BOT_MODE=maker tsx src/index.ts",
    "start:both": "BOT_MODE=both tsx src/index.ts",
    "dry": "DRY_RUN=true tsx src/index.ts",
    "keygen": "tsx src/keygen.ts",
    "health": "curl -s http://localhost:18820/health | jq .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@percolator/sdk": "workspace:*",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
